# --- Local (npm run start:dev) ---
DATABASE_URL="postgresql://premio:premio123@localhost:5432/premio_piaui?schema=public"
# Dev Postgres: docker compose -f docker-compose.dev.yml up -d → porta 5434
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"
PORT=3000

# --- Docker Compose (só backend) ---
APP_NAME=premio
ENV_NAME=prod
API_PORT=3000
DB_USER=premio
DB_PASSWORD=premio123
DB_NAME=premio_piaui
# true = roda seed ao subir (admin@premiopiaui.org / admin123)
RUN_SEED=true
